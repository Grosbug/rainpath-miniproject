# Prisma — relative to the backend/ directory in SQLite mode
DATABASE_URL="file:./dev.db"

# HTTP — defaults shown
PORT=3000

# Comma-separated list of CORS origins allowed to call /api.
# Example for prod: https://app.example.com,https://staging.app.example.com
CORS_ORIGIN=http://localhost:5173

# Pino log level — fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Pretty-print logs in dev only. Leave unset / false in prod for JSON logs.
LOG_PRETTY=true
